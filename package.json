{
  "name": "emergency-assistance",
  "version": "1.0.2",
  "description": "Emergency Assistance System - Full Stack Application",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "predev": "powershell -ExecutionPolicy Bypass -File scripts/kill-port-8080.ps1",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "cross-env NODE_ENV=development PORT=8080 NODE_OPTIONS=--no-warnings node --no-warnings server/unified-hot-reload-server.js",
    "dev:clean": "npm run predev && npm run dev",
    "dev:client": "npm --prefix client run vite-only",
    "start": "node server/server.mjs",
    "start:prod": "node --no-warnings server/server.mjs",
    "build": "echo No build needed - source code is deployed directly",
    "build:client": "npm --prefix client run build",
    "prebuild": "echo 🔨 Building client for production deployment...",
    "postbuild": "echo ✅ Client build completed. Ready for deployment!",
    "deploy-check": "node scripts/check-build-before-push.js",
    "pre-deploy": "node scripts/pre-deploy-check.mjs",
    "security:check-rsc": "node scripts/check-rsc-vulnerabilities.mjs",
    "pre-commit": "pwsh -File scripts/pre-commit.ps1",
    "commit": "npm run pre-commit && git add . && git commit",
    "pre-push": "npm run deploy-check",
    "docker:prod": "docker-compose up --build",
    "docker:prod:detach": "docker-compose up -d --build",
    "docker:dev": "docker-compose -f docker-compose.dev.yml up --build",
    "docker:dev:detach": "docker-compose -f docker-compose.dev.yml up -d --build",
    "docker:stop": "docker-compose down && docker-compose -f docker-compose.dev.yml down",
    "docker:clean": "docker-compose down -v --rmi all && docker-compose -f docker-compose.dev.yml down -v --rmi all",
    "docker:logs": "docker-compose logs -f",
    "docker:logs:dev": "docker-compose -f docker-compose.dev.yml logs -f"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "bcryptjs": "^2.4.3",
    "chardet": "^2.1.1",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.44.4",
    "express": "^4.21.2",
    "express-rate-limit": "^8.1.0",
    "express-session": "^1.18.2",
    "express-validator": "^7.2.1",
    "fs-extra": "^11.2.0",
    "fuse.js": "^7.1.0",
    "helmet": "^8.1.0",
    "http-proxy-middleware": "^3.0.5",
    "iconv-lite": "^0.7.1",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.11.0",
    "memorystore": "^1.6.7",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "openai": "^4.104.0",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.15.0",
    "pg": "^8.13.1",
    "postgres": "^3.4.4",
    "sharp": "^0.33.2",
    "uuid": "^13.0.0",
    "ws": "^8.18.0",
    "xlsx": "^0.18.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.22",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "husky": "^9.1.7",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.17",
    "vite": "^5.4.21"
  },
  "keywords": [
    "emergency",
    "assistance",
    "azure",
    "nodejs"
  ],
  "author": "Emergency Assistance Team",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/Satoshi-Niina/Emergency-Assistance.git"
  }
}
